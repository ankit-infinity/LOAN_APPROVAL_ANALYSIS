data("LakeHuron")
head(LakeHuron)
summary(LakeHuron)
class(LakeHuron)
print(dim(data.frame(LakeHuron)))
plot(LakeHuron,main='lakehuron water level',ylab='feet',col="blue",lwd= 2)
#stationarity checking
library(tseries)
adf_test=adf.test(LakeHuron)
adf_test
#making the data stationary
diff_lake=diff(LakeHuron)
plot(diff_lake,main="difference lake huron series",ylab='difference water level',col='red')
adf_diff_test=adf.test(diff_lake)
adf_diff_test
par(mfrow=c(1,2))
acf(diff_lake,main="acf")
pacf(diff_lake,main="pacf")
# arima model manual parameter selection using acf pacf
#arima(1,1,2)
manual=arima(LakeHuron,order =c(1,1,2))
print(manual)
#arima(1,1,1)
manual_1=arima(LakeHuron,order =c(1,1,1))
print(manual_1)
#arima(1,1,0)
manual_2=arima(LakeHuron,order =c(1,1,0))
print(manual_2)
#using auto arima
model=auto.arima(LakeHuron)
print(model)
